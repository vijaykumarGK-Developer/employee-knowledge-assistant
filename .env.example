# =============================================================================
# Employee Knowledge Assistant — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values before running:
#   cp .env.example .env
# =============================================================================

# --- PostgreSQL ---
# Connection string for the PostgreSQL database.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/employee_knowledge

# --- Auth ---
# Secret key for signing JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-secret-key-in-production

# JWT signing algorithm (default: HS256)
ALGORITHM=HS256

# Access token expiration in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- ChromaDB ---
# Host and port for the ChromaDB vector store service
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# --- Models ---
# Sentence-transformers model for generating embeddings
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# HuggingFace model for LLM answer generation
LLM_MODEL=google/flan-t5-base

# --- File Uploads ---
# Directory where uploaded files are stored
UPLOAD_DIR=uploads

# Maximum upload file size in bytes (default: 50MB)
MAX_UPLOAD_SIZE=52428800

# --- CORS ---
# Comma-separated list of allowed origins for CORS (production)
# Example: https://yourdomain.com,https://admin.yourdomain.com
CORS_ORIGINS=http://localhost:3000
